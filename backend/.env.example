# ╔══════════════════════════════════════════════════════════════════╗
# ║           CodeSentinel — Environment Variables                   ║
# ║  Copy to .env and fill in your values before running            ║
# ╚══════════════════════════════════════════════════════════════════╝

# ── Application ────────────────────────────────────────────────────
APP_NAME=CodeSentinel
APP_VERSION=1.0.0
APP_ENV=development
DEBUG=true
SECRET_KEY=CHANGE_THIS_TO_RANDOM_64_CHAR_STRING_IN_PRODUCTION
FRONTEND_URL=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Database (PostgreSQL) ──────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://codesentinel:password@localhost:5432/codesentinel
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# ── Redis + Celery ─────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ── JWT ────────────────────────────────────────────────────────────
JWT_SECRET_KEY=CHANGE_THIS_TO_ANOTHER_RANDOM_64_CHAR_STRING
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Fernet Encryption for stored secrets/tokens ────────────────────
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# ── GitHub App ─────────────────────────────────────────────────────
# Create at: https://github.com/settings/apps/new
# Required webhook events: pull_request, push, check_run, check_suite
# Required permissions: Contents(R), Pull requests(RW), Checks(RW),
#   Issues(RW), Metadata(R), Commit statuses(RW)
GITHUB_APP_ID=
GITHUB_APP_NAME=codesentinel
# Full PEM key with literal \n for newlines (env-safe format)
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_WEBHOOK_SECRET=
GITHUB_WEBHOOK_URL=
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=

# ── GitLab OAuth App (optional) ────────────────────────────────────
GITLAB_APP_ID=
GITLAB_APP_SECRET=
GITLAB_WEBHOOK_SECRET=

# ── Bitbucket OAuth (optional) ─────────────────────────────────────
BITBUCKET_APP_KEY=
BITBUCKET_APP_SECRET=
BITBUCKET_WEBHOOK_SECRET=

# ── AI: Ollama local (FREE, no registration) ───────────────────────
# Install: https://ollama.com/download  then: ollama pull codellama:13b
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_DEFAULT_MODEL=codellama:13b
OLLAMA_TIMEOUT=120

# ── AI: Groq free tier (FREE, just register) ──────────────────────
# Register at https://console.groq.com — free, no credit card
GROQ_API_KEY=
GROQ_DEFAULT_MODEL=llama-3.1-70b-versatile

# ── AI: Optional paid providers (bring-your-own-key) ──────────────
OPENAI_API_KEY=
OPENAI_DEFAULT_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=
ANTHROPIC_DEFAULT_MODEL=claude-3-5-sonnet-20241022
GEMINI_API_KEY=
OPENROUTER_API_KEY=

# ── Notifications ──────────────────────────────────────────────────
SLACK_BOT_TOKEN=
SLACK_DEFAULT_CHANNEL=#security-alerts
TEAMS_WEBHOOK_URL=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@codesentinel.dev

# ── Issue Trackers ─────────────────────────────────────────────────
JIRA_BASE_URL=
JIRA_API_TOKEN=
JIRA_USER_EMAIL=
JIRA_PROJECT_KEY=SEC
LINEAR_API_KEY=
LINEAR_TEAM_ID=

# ── Rate Limiting ──────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60
SCAN_RATE_LIMIT_PER_HOUR=100
